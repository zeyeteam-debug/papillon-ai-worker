# Copy this file to the PUBLIC repo: zeyeteam-debug/papillon-ai-worker
# as .github/workflows/update-worker.yml
#
# Required secrets in papillon-ai-worker repo:
#   - SOURCE_REGISTRY_USER  (Docker Hub username that can pull the private image)
#   - SOURCE_REGISTRY_TOKEN (Docker Hub token or password)
#   - DEST_REGISTRY_TOKEN   (e.g. GHCR token with write to ghcr.io/zeyeteam-debug/papillon-ai-worker)
#
# Set SOURCE_IMAGE and DEST_IMAGE in the workflow or as repo variables to match your registries.
# Example: source = docker.io/USER/papillon-ai-worker:latest, dest = ghcr.io/zeyeteam-debug/papillon-ai-worker:latest

name: Mirror image on update_worker

on:
  repository_dispatch:
    types: [update_worker]

jobs:
  mirror:
    runs-on: ubuntu-latest
    steps:
      - name: Install crane
        uses: imjasonh/setup-crane@v0.4
        with:
          version: "v0.19.2"

      - name: Log in to source registry (Docker Hub)
        run: |
          echo "${{ secrets.SOURCE_REGISTRY_TOKEN }}" | crane auth login docker.io -u "${{ secrets.SOURCE_REGISTRY_USER }}" --password-stdin

      - name: Log in to destination registry (GHCR)
        run: |
          echo "${{ secrets.DEST_REGISTRY_TOKEN }}" | crane auth login ghcr.io -u "${{ github.repository_owner }}" --password-stdin

      - name: Copy image to public registry
        env:
          SOURCE_IMAGE: docker.io/${{ secrets.SOURCE_REGISTRY_USER }}/papillon-ai-worker:latest
          DEST_IMAGE: ghcr.io/zeyeteam-debug/papillon-ai-worker:latest
        run: |
          crane copy "$SOURCE_IMAGE" "$DEST_IMAGE"
